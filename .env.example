# AWS Configuration
AWS_REGION=af-south-1
AWS_PROFILE=              # Set for local dev, empty on Lambda (uses execution role)

# DynamoDB Tables
ORGANISATIONS_TABLE=supsim-organisations-dev
APP_CONFIG_TABLE=supsim-app-config-dev

# Athena / Glue
GLUE_DATABASE=supsim_dev
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_BUCKET=supsim-athena-results-dev

# Cognito (for user management Lambda)
COGNITO_USER_POOL_ID=

# Application
ENVIRONMENT=dev
LOG_LEVEL=INFO
